#!/usr/bin/env python3
"""YuanForge pre-commit hook — 确定性校验。

保证 LLM 永远不会污染 Docs。

校验项:
  1. YAML syntax — object-model.yaml + 所有 frontmatter
  2. Enum validation — object_type/status/confidence/lifecycle 合法值
  3. Frontmatter completeness — 必填字段检查
  4. Proposal validation — Proposal 必填字段
  5. Anchor integrity — 分段锚点完整性检查
"""

import sys
import os
import re
import subprocess
from pathlib import Path

REPO_ROOT = Path(subprocess.check_output(
    ['git', 'rev-parse', '--show-toplevel'], text=True
).strip())

# ── 1. Changed files ──────────────────────────────────────────────

changed = subprocess.check_output(
    ['git', 'diff', '--cached', '--name-only', '--diff-filter=ACM'],
    text=True
).strip().split('\n')

changed = [f for f in changed if f]  # filter empty

if not changed:
    sys.exit(0)

# ── 2. YAML validation ────────────────────────────────────────────

yaml_files = [f for f in changed if f.endswith(('.yaml', '.yml'))]

if yaml_files:
    import yaml
    for f in yaml_files:
        path = REPO_ROOT / f
        try:
            with open(path) as fh:
                yaml.safe_load(fh)
        except yaml.YAMLError as e:
            print(f"[ERROR] YAML syntax error in {f}: {e}")
            sys.exit(1)

# ── 3. Frontmatter validation ─────────────────────────────────────

VALID_OBJECT_TYPES = {'feature', 'decision', 'pitfall', 'module'}
VALID_CONFIDENCE = {'verified', 'stale', 'draft', 'deprecated'}
VALID_LIFECYCLE = {'knowledge'}
VALID_FEATURE_STATUS = {'draft', 'designed', 'implemented', 'verified', 'deprecated'}
VALID_DECISION_STATUS = {'proposed', 'accepted', 'deprecated', 'superseded'}
VALID_PITFALL_STATUS = {'active', 'resolved', 'archived'}
VALID_MODULE_STATUS = {'active', 'deprecated'}

REQUIRED_FIELDS = {'id', 'object_type', 'lifecycle', 'owner', 'status', 'summary', 'confidence'}

md_files = [f for f in changed if f.endswith('.md')]

for f in md_files:
    path = REPO_ROOT / f
    if not path.exists():
        continue
    content = path.read_text()
    
    # Check for YAML frontmatter
    if not content.startswith('---'):
        continue
    
    # Extract frontmatter
    parts = content.split('---', 2)
    if len(parts) < 3:
        continue
    
    try:
        import yaml
        fm = yaml.safe_load(parts[1])
    except Exception:
        continue  # not YAML frontmatter
    
    if not fm or not isinstance(fm, dict):
        continue
    
    # Skip non-knowledge files (specs, rules, contracts, etc.)
    object_type = fm.get('object_type', '')
    if object_type not in VALID_OBJECT_TYPES:
        continue
    
    # ── 3a. Required fields ──
    missing = REQUIRED_FIELDS - set(fm.keys())
    if missing:
        print(f"[ERROR] {f}: missing required frontmatter fields: {missing}")
        sys.exit(1)
    
    # ── 3b. Enum validation ──
    if fm['object_type'] not in VALID_OBJECT_TYPES:
        print(f"[ERROR] {f}: invalid object_type '{fm['object_type']}'")
        sys.exit(1)
    
    if fm['confidence'] not in VALID_CONFIDENCE:
        print(f"[ERROR] {f}: invalid confidence '{fm['confidence']}'")
        sys.exit(1)
    
    if fm['lifecycle'] not in VALID_LIFECYCLE:
        print(f"[ERROR] {f}: invalid lifecycle '{fm['lifecycle']}'")
        sys.exit(1)
    
    # ── 3c. Type-specific status validation ──
    status = fm['status']
    if object_type == 'feature' and status not in VALID_FEATURE_STATUS:
        print(f"[ERROR] {f}: invalid feature status '{status}'")
        sys.exit(1)
    elif object_type == 'decision' and status not in VALID_DECISION_STATUS:
        print(f"[ERROR] {f}: invalid decision status '{status}'")
        sys.exit(1)
    elif object_type == 'pitfall' and status not in VALID_PITFALL_STATUS:
        print(f"[ERROR] {f}: invalid pitfall status '{status}'")
        sys.exit(1)
    elif object_type == 'module' and status not in VALID_MODULE_STATUS:
        print(f"[ERROR] {f}: invalid module status '{status}'")
        sys.exit(1)

# ── 4. Proposal validation ────────────────────────────────────────

proposal_files = [f for f in changed if 'proposals/' in f and f.endswith('.md')]

for f in proposal_files:
    path = REPO_ROOT / f
    if not path.exists():
        continue
    content = path.read_text()
    if not content.startswith('---'):
        print(f"[ERROR] {f}: proposal missing frontmatter")
        sys.exit(1)
    
    parts = content.split('---', 2)
    if len(parts) < 3:
        print(f"[ERROR] {f}: proposal frontmatter malformed")
        sys.exit(1)
    
    try:
        import yaml
        fm = yaml.safe_load(parts[1])
    except Exception as e:
        print(f"[ERROR] {f}: proposal YAML error: {e}")
        sys.exit(1)
    
    prop_required = {'id', 'status', 'target_object', 'change_type', 'summary'}
    missing = prop_required - set(fm.keys())
    if missing:
        print(f"[ERROR] {f}: proposal missing required fields: {missing}")
        sys.exit(1)
    
    valid_change_types = {'distill', 'update', 'deprecate'}
    if fm.get('change_type') not in valid_change_types:
        print(f"[ERROR] {f}: invalid change_type '{fm.get('change_type')}'")
        sys.exit(1)

# ── 5. Anchor integrity ───────────────────────────────────────────

# Define required anchors per file
REQUIRED_ANCHORS = {
    '.yuan/rules/iron-rules.md': [f'<SECTION-END:{i}>' for i in range(1, 11)],
    'contracts/conductor.md': [
        '<SECTION-END:conductor-schedule>',
        '<SECTION-END:conductor-tier>',
        '<SECTION-END:conductor-forbidden>',
        '<SECTION-END:conductor-exit>',
        '<SECTION-END:conductor-session-log>',
    ],
    '.yuan/docs/TASK_BOARD.md': [
        '<SECTION-END:tb-statuses>',
        '<SECTION-END:tb-snapshot>',
        '<SECTION-END:tb-context>',
        '<SECTION-END:tb-faults>',
        '<SECTION-END:tb-rework>',
        '<SECTION-END:tb-blocked>',
        '<SECTION-END:tb-reviews>',
        '<SECTION-END:tb-schedule>',
        '<SECTION-END:tb-dispatch-log>',
        '<SECTION-END:tb-agent-startup>',
        '<SECTION-END:tb-fields>',
        '<SECTION-END:tb-lifecycle>',
        '<SECTION-END:tb-context-rules>',
        '<SECTION-END:tb-rework-rules>',
        '<SECTION-END:tb-cancel-rules>',
        '<SECTION-END:tb-timeout-rules>',
        '<SECTION-END:tb-cross-session>',
        '<SECTION-END:tb-isolation>',
        '<SECTION-END:tb-roles>',
        '<SECTION-END:tb-concurrency>',
        '<SECTION-END:tb-final>',
    ],
    '.yuan/docs/SESSION.md': [
        '<SECTION-END:session-distill>',
        '<SECTION-END:session-crash-recovery>',
        '<SECTION-END:session-snapshot>',
        '<SECTION-END:session-id>',
        '<SECTION-END:session-final>',
    ],
}

# Only check files that are staged for commit
staged_files = set(changed)

for filepath, required_anchors in REQUIRED_ANCHORS.items():
    if filepath not in staged_files:
        continue
    
    path = REPO_ROOT / filepath
    if not path.exists():
        print(f"⚠️  {filepath}: file not found, skipping anchor check")
        continue
    
    content = path.read_text()
    missing = []
    for anchor in required_anchors:
        if anchor not in content:
            missing.append(anchor)
    
    if missing:
        print(f"❌ {filepath}: missing required anchors: {missing}")
        sys.exit(1)
    else:
        print(f"  ✓ {filepath}: all {len(required_anchors)} anchors present")

# ── All good ───────────────────────────────────────────────────────

print("[OK] YuanForge pre-commit: all validations passed")
sys.exit(0)
