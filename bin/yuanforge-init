# DocsOS — Graph 是 Build Artifact
docs/graph/index.json
"""


# ═══════════════════════════════════════════════════════════
# 辅助函数
# ═══════════════════════════════════════════════════════════

def color(text: str, code: str) -> str:
    colors = {"red": "31", "green": "32", "yellow": "33", "cyan": "36", "bold": "1"}
    c = colors.get(code, "0")
    return f"\033[{c}m{text}\033[0m"


def file_sha256(path: Path) -> str:
    """返回文件的 SHA256 摘要。用于内容对比。"""
    if not path.is_file():
        return ""
    return hashlib.sha256(path.read_bytes()).hexdigest()


def sync_directory(
    src_dir: Path,
    dst_dir: Path,
    dry_run: bool = False,
    clean_orphans: bool = False,
) -> dict:
    """增量同步目录：新增/更新/不变/孤文件。

    返回: {relpath: action} 其中 action ∈ {added, updated, skipped, orphaned}
    """
    results = {}
    src_root = src_dir
    dst_root = dst_dir

    if not dry_run:
        dst_root.mkdir(parents=True, exist_ok=True)

    # ── 收集源文件 ──
    src_files: dict[str, Path] = {}
    for f in src_root.rglob("*"):
        if f.is_file():
            rel = str(f.relative_to(src_root))
            src_files[rel] = f

    # ── 收集目标文件 ──
    dst_files: dict[str, Path] = {}
    if dst_root.exists():
        for f in dst_root.rglob("*"):
            if f.is_file():
                rel = str(f.relative_to(dst_root))
                dst_files[rel] = f

    # ── 对比并同步 ──
    for rel, src_path in sorted(src_files.items()):
        dst_path = dst_root / rel

        if rel not in dst_files:
            # 新增
            if not dry_run:
                dst_path.parent.mkdir(parents=True, exist_ok=True)
                shutil.copy2(src_path, dst_path)
            results[rel] = "added"

        elif file_sha256(src_path) != file_sha256(dst_path):
            # 内容变更 → 覆盖
            if not dry_run:
                shutil.copy2(src_path, dst_path)
            results[rel] = "updated"

        else:
            # 内容未变
            results[rel] = "skipped"

    # ── 检查孤文件（目标有但源没有）──
    orphans = []
    for rel in sorted(dst_files.keys()):
        if rel not in src_files:
            # 跳过 .gitkeep
            if Path(rel).name == ".gitkeep":
                continue
            orphans.append(rel)

    if orphans and clean_orphans and not dry_run:
        for rel in orphans:
            (dst_root / rel).unlink(missing_ok=True)
        results["__orphans_cleaned__"] = orphans

    elif orphans:
        results["__orphans__"] = orphans

    return results


def sync_framework_item(
    item: str,
    src_root: Path,
    dst_root: Path,
    dry_run: bool = False,
    clean_orphans: bool = False,
) -> dict:
    """同步一个框架项（文件或目录）。"""
    src = src_root / item
    dst = dst_root / item

    if src.is_dir():
        return sync_directory(src, dst, dry_run, clean_orphans)
    else:
        # 单文件
        if not dst.exists():
            if not dry_run:
                dst.parent.mkdir(parents=True, exist_ok=True)
                shutil.copy2(src, dst)
            return {item: "added"}
        elif file_sha256(src) != file_sha256(dst):
            if not dry_run:
                shutil.copy2(src, dst)
            return {item: "updated"}
        else:
            return {item: "skipped"}


def create_docs_skeleton(target: Path, mode: str, dry_run: bool = False) -> dict:
    """创建 docs/ 目录骨架。返回 {路径: 动作}"""
    docs_dir = target / "docs"
    results = {}

    if not dry_run:
        docs_dir.mkdir(parents=True, exist_ok=True)

    for subdir in DOCS_SKELETON_DIRS:
        dirpath = docs_dir / subdir
        if dirpath.exists():
            results[subdir + "/"] = "skipped"
            continue
        if not dry_run:
            dirpath.mkdir(parents=True, exist_ok=True)
            (dirpath / ".gitkeep").touch()
        results[subdir + "/"] = "created"

    for relpath, content in DOCS_SKELETON_FILES.items():
        filepath = docs_dir / relpath
        if filepath.exists() and mode == "existing":
            results[relpath] = "skipped"
            continue
        if dry_run:
            results[relpath] = "created" if not filepath.exists() else "skipped"
        else:
            filepath.parent.mkdir(parents=True, exist_ok=True)
            filepath.write_text(content, encoding="utf-8")
            results[relpath] = "created"

    return results


def cleanup_known_stale(target: Path, dry_run: bool = False) -> list:
    """删除已知的旧文件/目录。"""
    removed = []
    for relpath in KNOWN_STALE_PATHS:
        filepath = target / relpath
        if not filepath.exists():
            continue
        if not dry_run:
            if filepath.is_dir():
                shutil.rmtree(filepath)
            else:
                filepath.unlink()
        removed.append(relpath)
    return removed


def generate_gitignore(target: Path, dry_run: bool = False) -> str:
    """生成 .gitignore。已有则跳过。"""
    filepath = target / ".gitignore"
    if filepath.exists():
        return "skipped"
    if not dry_run:
        filepath.write_text(GITIGNORE_CONTENT, encoding="utf-8")
    return "created"


def read_target_version(target: Path) -> str:
    """读取目标项目的框架版本。"""
    ver_file = target / ".yuan" / "VERSION"
    if ver_file.exists():
        return ver_file.read_text().strip()
    return "none"


def write_target_version(target: Path, dry_run: bool = False):
    """写入当前框架版本到目标。"""
    if dry_run:
        return
    ver_file = target / ".yuan" / "VERSION"
    ver_file.parent.mkdir(parents=True, exist_ok=True)
    ver_file.write_text(FRAMEWORK_VERSION + "\n")


# ═══════════════════════════════════════════════════════════
# 输出
# ═══════════════════════════════════════════════════════════

def print_sync_summary(results: dict, label: str):
    """打印同步摘要。"""
    added = [k for k, v in results.items() if v == "added" and not k.startswith("__")]
    updated = [k for k, v in results.items() if v == "updated" and not k.startswith("__")]
    skipped = [k for k, v in results.items() if v == "skipped" and not k.startswith("__")]
    orphans = results.get("__orphans__", [])
    cleaned = results.get("__orphans_cleaned__", [])

    print(f"\n{color(label, 'bold')}")

    if added:
        print(color(f"  + {len(added)} new:", "green"))
        for f in added[:10]:
            print(f"      {f}")
        if len(added) > 10:
            print(f"      ... and {len(added) - 10} more")

    if updated:
        print(color(f"  ~ {len(updated)} updated:", "yellow"))
        for f in updated[:10]:
            print(f"      {f}")
        if len(updated) > 10:
            print(f"      ... and {len(updated) - 10} more")

    if skipped:
        print(f"  · {len(skipped)} unchanged (skipped)")

    if cleaned:
        print(color(f"  - {len(cleaned)} orphaned files cleaned:", "red"))
        for f in cleaned[:10]:
            print(f"      {f}")
        if len(cleaned) > 10:
            print(f"      ... and {len(cleaned) - 10} more")

    if orphans:
        print(color(f"  ! {len(orphans)} orphaned files (not in source):", "yellow"))
        for f in orphans[:10]:
            print(f"      {f}")
        if len(orphans) > 10:
            print(f"      ... and {len(orphans) - 10} more")
        print(color("    Use --clean to remove them", "yellow"))


def print_help_new(target: str):
    print()
    print(color("✅ YuanForge 初始化完成", "green"))
    print(f"📂 {target}")
    print()
    print(color("╔══════════════════════════════════════════╗", "cyan"))
    print(color("║  🚀 下一步                                ║", "cyan"))
    print(color("╠══════════════════════════════════════════╣", "cyan"))
    print(color("║  向 Conductor 描述你的需求:               ║", "cyan"))
    print(color('║  "我要做一个 xxx"                        ║', "cyan"))
    print(color("║  Conductor 启动 12 人专家团               ║", "cyan"))
    print(color("╚══════════════════════════════════════════╝", "cyan"))
    print()


def print_help_existing(target: str, stale_cleaned: list):
    print()
    print(color("✅ YuanForge 嫁接 / 同步完成", "green"))
    print(f"📂 {target}")
    if stale_cleaned:
        print()
        print(color("🧹 已清理已知旧文件:", "yellow"))
        for item in stale_cleaned:
            print(f"  🗑 {item}")
    print()
    print(color("╔══════════════════════════════════════════╗", "cyan"))
    print(color("║  🚀 下一步                                ║", "cyan"))
    print(color("╠══════════════════════════════════════════╣", "cyan"))
    print(color("║  1. 先补全项目文档:                       ║", "cyan"))
    print(color("║     「请审计当前项目，生成 docs/ 文档」    ║", "cyan"))
    print(color("║  2. 再描述新需求:                         ║", "cyan"))
    print(color("║     「在现有项目基础上，我要增加 xxx」      ║", "cyan"))
    print(color("╚══════════════════════════════════════════╝", "cyan"))
    print()


def print_help_sync(target: str, from_ver: str):
    print()
    print(color("✅ YuanForge 增量同步完成", "green"))
    print(f"📂 {target}")
    if from_ver and from_ver != "none":
        print(f"   {from_ver} → {FRAMEWORK_VERSION}")
    print()
    print(color("  运行 git diff --stat 查看变更", "cyan"))
    print()


# ═══════════════════════════════════════════════════════════
# 主逻辑
# ═══════════════════════════════════════════════════════════

def main():
    parser = argparse.ArgumentParser(
        description="YuanForge 项目初始化 / 框架同步",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=textwrap.dedent("""\
            示例:
              yuanforge-init ./my-app                          从零开始
              yuanforge-init ./my-app --name "用户认证系统"      指定项目名
              yuanforge-init ./existing --mode existing         嫁接已有项目
              yuanforge-init ./existing --mode existing --clean 嫁接 + 清理孤文件
              yuanforge-init ./project --mode existing --update 仅更新框架文件
              yuanforge-init ./project --sync                  智能增量同步
              yuanforge-init ./my-app --dry-run                 预览
        """),
    )
    parser.add_argument("target", help="目标项目目录")
    parser.add_argument("--name", default=None, help="项目名称")
    parser.add_argument(
        "--mode", choices=["new", "existing"], default="new",
        help="new=从零开始(默认), existing=嫁接/更新已有项目",
    )
    parser.add_argument("--sync", action="store_true",
                        help="智能增量同步：对比源和目标，新增/更新/检测孤文件")
    parser.add_argument("--update", action="store_true",
                        help="仅更新框架文件，不操作 docs/（需配合 --mode existing）")
    parser.add_argument("--clean", action="store_true",
                        help="清理已知旧文件 + 孤文件（需配合 --mode existing 或 --sync）")
    parser.add_argument("--dry-run", action="store_true", help="只显示会做什么，不执行")
    parser.add_argument("--force", action="store_true", help="跳过确认")

    args = parser.parse_args()
    target = Path(args.target).resolve()

    # ── 验证源目录 ──
    for item in ALL_FRAMEWORK_ITEMS:
        src = SOURCE_ROOT / item
        if not src.exists():
            print(color(f"✗ 框架文件缺失: {src}", "red"))
            print("  请确保从 yuanforge 仓库根目录运行此脚本")
            sys.exit(1)

    # ── 如果指定 --sync，自动使用 existing + update 模式 ──
    if args.sync:
        args.mode = "existing"
        args.update = True

    # ── 模式验证 ──
    if args.mode == "new":
        if target.exists() and any(target.iterdir()):
            print(color(f"✗ 目标目录已有文件: {target}", "red"))
            print("  --mode new 要求目标目录不存在或为空")
            print("  如果是已有项目，请使用 --mode existing 或 --sync")
            sys.exit(1)
    elif args.mode == "existing":
        if not target.exists():
            print(color(f"✗ 目标目录不存在: {target}", "red"))
            print("  --mode existing 要求目标目录已存在")
            sys.exit(1)

    # ── 版本信息（仅展示，不阻止同步）──
    from_version = ""
    if args.mode == "existing":
        from_version = read_target_version(target)
        if from_version and from_version != "none":
            print(color(f"  当前框架版本: {from_version} → {FRAMEWORK_VERSION}", "yellow"))

    # ── 确认 ──
    if not args.force and not args.dry_run:
        print()
        print(f"  目标: {target}")
        if args.mode == "new":
            print("  模式: 从零开始")
        elif args.sync:
            print("  模式: 智能增量同步")
        elif args.update:
            print("  模式: 仅更新框架文件")
        else:
            print("  模式: 嫁接已有项目")
        if args.clean:
            print("  清理: 是（已知旧文件 + 孤文件）")
        print()
        confirm = input("  确认? [Y/n] ").strip().lower()
        if confirm and confirm != "y":
            print("  已取消")
            sys.exit(0)

    # ═══ 执行 ═══
    if args.dry_run:
        print(color("\n🔍 预览模式 — 不会实际修改文件\n", "yellow"))

    if not args.dry_run:
        target.mkdir(parents=True, exist_ok=True)

    # ── 1. 清理已知旧文件 ──
    stale_cleaned = []
    if args.clean:
        print(color("🧹 清理已知旧文件:", "bold"))
        stale_cleaned = cleanup_known_stale(target, args.dry_run)
        if stale_cleaned:
            for item in stale_cleaned:
                print(f"  🗑 {item}")
        else:
            print("  · 没有需要清理的已知旧文件")

    # ── 2. 同步框架子目录（粒度化 diff）──
    print(color("\n📋 同步框架 (.yuan/ subdirs):", "bold"))
    for subdir in FRAMEWORK_SUBDIRS:
        src = SOURCE_ROOT / subdir
        results = sync_framework_item(subdir, SOURCE_ROOT, target, args.dry_run, args.clean)
        added = sum(1 for v in results.values() if v == "added")
        updated = sum(1 for v in results.values() if v == "updated")
        orphans = results.get("__orphans__", [])
        cleaned = results.get("__orphans_cleaned__", [])
        parts = []
        if added: parts.append(f"+{added}")
        if updated: parts.append(f"~{updated}")
        if cleaned: parts.append(color(f"-{len(cleaned)}", "red"))
        elif orphans: parts.append(color(f"!{len(orphans)} orphaned", "yellow"))
        if parts:
            print(f"  {subdir}: {' '.join(parts)}")
            if orphans:
                for f in orphans[:5]:
                    print(f"      ! {f}")
                if len(orphans) > 5:
                    print(f"      ... and {len(orphans) - 5} more (use --clean to remove)")

    # ── 3. 同步框架顶层目录（增量同步，不清理孤儿保护用户自定义文件）──
    print(color("\n📋 同步框架 (contracts/protocols/templates/scripts):", "bold"))
    for topdir in FRAMEWORK_TOP_DIRS:
        src = SOURCE_ROOT / topdir
        results = sync_framework_item(topdir, SOURCE_ROOT, target, args.dry_run, clean_orphans=False)
        added = sum(1 for v in results.values() if v == "added")
        updated = sum(1 for v in results.values() if v == "updated")
        skipped = sum(1 for v in results.values() if v == "skipped")
        if added or updated or skipped:
            print(f"  {topdir}/: +{added} ~{updated} ·{skipped}")

    # ── 4. 同步框架单文件 ──
    print(color("\n📋 同步框架文件:", "bold"))
    for f in FRAMEWORK_FILES:
        results = sync_framework_item(f, SOURCE_ROOT, target, args.dry_run, args.clean)
        for rel, action in results.items():
            if action == "added":
                print(f"  + {rel}")
            elif action == "updated":
                print(f"  ~ {rel}")

    # ── 5. 写入版本 ──
    if not args.dry_run:
        write_target_version(target)

    # ── 6. 生成 docs/ ──
    if not args.update:
        print(color("\n📄 生成 docs/ 骨架:", "bold"))
        doc_results = create_docs_skeleton(target, args.mode, args.dry_run)
        created = sum(1 for v in doc_results.values() if v == "created")
        skipped = sum(1 for v in doc_results.values() if v == "skipped")
        print(f"  +{created} created, ·{skipped} skipped")
    else:
        print(color("\n📄 docs/ → 跳过（--update 模式）", "bold"))

    # ── 7. .gitignore ──
    print(color("\n📄 .gitignore:", "bold"))
    git_status = generate_gitignore(target, args.dry_run)
    if git_status == "created":
        print("  ✓ .gitignore")
    else:
        print("  · .gitignore → 跳过（已存在）")

    # ── 8. git init (仅 new 模式) ──
    if args.mode == "new" and not args.dry_run:
        print(color("\n📦 git init:", "bold"))
        result = subprocess.run(
            ["git", "init"], cwd=target, capture_output=True, text=True
        )
        print(f"  {result.stdout.strip()}")

    # ═══ 完成 ═══
    if args.dry_run:
        print(color("\n🔍 预览完成 — 以上操作不会实际执行", "yellow"))
        return

    if args.mode == "new":
        print_help_new(str(target))
    elif args.sync:
        print_help_sync(str(target), from_version)
    else:
        print_help_existing(str(target), stale_cleaned)


if __name__ == "__main__":
    main()
