    "policies/verification-policy.md":  "# 知识验证规则\n",
}

# ── 已知的旧文件/目录（迁移时清理）──
KNOWN_STALE_PATHS = [
    # 旧版踩坑文件 → knowledge/pitfalls/
    "docs/pitfalls.md",
