#!/usr/bin/env python3
"""YuanForge 项目初始化 / 框架同步脚本

用法:
  yuanforge-init /path/to/new-project                     # 从零开始
  yuanforge-init /path/to/new-project --name "我的项目"     # 指定项目名
  yuanforge-init /path/to/existing --mode existing         # 嫁接已有项目
  yuanforge-init /path/to/existing --mode existing --clean # 嫁接 + 清理孤文件
  yuanforge-init /path/to/project --mode existing --update # 仅同步框架文件
  yuanforge-init /path/to/project --sync                  # 智能增量同步（推荐日常使用）
  yuanforge-init /path/to/new-project --dry-run            # 预览不执行

模式说明:
  从零开始 (--mode new):        目标目录必须不存在或为空
  嫁接已有 (--mode existing):   目标目录已存在。框架文件覆盖，docs/ 补缺不覆盖
  框架更新 (--mode existing --update): 仅覆盖框架文件，不操作 docs/ 和 git
  增量同步 (--sync):            智能 diff — 新增/更新/删除，内容不变跳过
"""

import argparse
import hashlib
import os
import shutil
import subprocess
import sys
import textwrap
from pathlib import Path

# ═══════════════════════════════════════════════════════════
# 配置
# ═══════════════════════════════════════════════════════════

SCRIPT_DIR = Path(__file__).resolve().parent
SOURCE_ROOT = SCRIPT_DIR.parent

FRAMEWORK_VERSION = "3.0.0"

# ── 框架子目录（粒度化，区分框架数据 vs 项目数据）──
# 框架数据 — 从源完全同步（增/改/删）
FRAMEWORK_SUBDIRS = [
    ".yuan/specs",
    ".yuan/docs",
    ".yuan/rules",
    ".yuan/skills",
    ".yuan/platforms",
]

# 框架顶层目录 — 改为增量同步（不再 rmtree+copytree，保护用户自定义文件）
FRAMEWORK_TOP_DIRS = [
    "contracts",
    "protocols",
    "templates",
    "scripts",
]

# 框架单文件
FRAMEWORK_FILES = [
    "AGENTS.md",
]

# 项目数据目录 — 更新时永不触碰
PROTECTED_DIRS = [
    ".yuan/skills/user-",  # 用户自定义 skill（目录名前缀）
    "docs/knowledge/features/",  # 用户自定义知识
    "docs/knowledge/modules/",
]

# 所有框架同步项（用于验证源完整性）
ALL_FRAMEWORK_ITEMS = (
    FRAMEWORK_SUBDIRS + FRAMEWORK_TOP_DIRS + FRAMEWORK_FILES
)

# ── docs/ 骨架 ──
DOCS_SKELETON_DIRS = [
    "knowledge/features",
