#!/usr/bin/env python3
"""YuanForge 项目初始化 / 框架更新脚本

用法:
  yuanforge-init /path/to/new-project                     # 从零开始
  yuanforge-init /path/to/new-project --name "我的项目"     # 指定项目名
  yuanforge-init /path/to/existing --mode existing         # 嫁接已有项目
  yuanforge-init /path/to/existing --mode existing --clean # 嫁接 + 清理旧模板
  yuanforge-init /path/to/project --mode existing --update # 仅更新框架文件
  yuanforge-init /path/to/new-project --dry-run            # 预览不执行

从零开始: 目标目录必须不存在或为空
嫁接已有: 目标目录必须存在。框架文件强制覆盖，docs/ 文件只补缺不覆盖
框架更新: 仅覆盖框架文件 (.yuan/ contracts/ protocols/ templates/ scripts/ AGENTS.md)
"""

import argparse
import os
import shutil
import sys
import textwrap
from pathlib import Path


# ═══════════════════════════════════════════════════════════
# 配置
# ═══════════════════════════════════════════════════════════

SCRIPT_DIR = Path(__file__).resolve().parent
SOURCE_ROOT = SCRIPT_DIR.parent

# 框架文件 — 总是覆盖更新
FRAMEWORK_ITEMS = [
    ".yuan",
    "contracts",
    "protocols",
    "templates",
    "scripts",
    "AGENTS.md",
]

# docs/ 目录骨架 — 只补缺不覆盖
DOCS_SKELETON_DIRS = [
    "knowledge/features",
    "knowledge/decisions",
    "knowledge/pitfalls",
    "knowledge/modules",
    "workspace",
    "policies",
    "events",
    "proposals/architect",
    "proposals/backend-dev",
    "proposals/frontend-dev",
    "proposals/closed",
    "graph",
    "archive",
]

DOCS_SKELETON_FILES = {
    "object-model.yaml":  "# 知识对象 Schema — 从 yuanforge 框架模板复制\n",
    "INDEX.md":           "# 文档索引\n",
    "PROGRESS.md":        "# 项目进度\n\n> 当前 Phase: 初始化\n",
    "ARCHITECTURE.md":    "# 系统架构\n",
    "SETUP.md":           "# 环境搭建\n",
    "CONVENTIONS.md":     "# 编码规范\n",
    "glossary.md":        "# 术语表\n",
    "workspace/backlog.md": "# 待办事项\n\n> 蒸馏时 Workspace 未完成任务自动追加到此文件\n",
    "workspace/roadmap.md": "# 路线图\n",
    "policies/write-policy.md":         "# Knowledge 写入规则\n\n> 框架模板 — 见 yuanforge 母体的 policies/\n",
    "policies/merge-policy.md":         "# Proposal 合并规则\n",
    "policies/archive-policy.md":       "# Workspace 归档规则\n",
    "policies/verification-policy.md":  "# 知识验证规则\n",
}

GITIGNORE_CONTENT = """\
# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
.venv/
venv/

# Node.js
node_modules/

# 环境变量
.env
.env.local

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# 构建产物
build/
*.log

# DocsOS — Graph 是 Build Artifact
docs/graph/index.json
"""

# old mode 下需要删除的旧模板（如果存在）
OLD_TEMPLATE_FILES = [
    "docs/pitfalls.md",     # 旧版 pitfalls 已迁移到 knowledge/pitfalls/
]

OLD_TEMPLATE_DIRS = [
    # 没有旧目录需要删除 — 旧版没有 knowledge/ workspace/ 等
]


# ═══════════════════════════════════════════════════════════
# 辅助函数
# ═══════════════════════════════════════════════════════════

def color(text: str, code: str) -> str:
    colors = {"red": "31", "green": "32", "yellow": "33", "cyan": "36", "bold": "1"}
    c = colors.get(code, "0")
    return f"\033[{c}m{text}\033[0m"


def copy_framework_item(src: Path, dst_dir: Path, dry_run: bool = False) -> str:
    """复制框架文件/目录到目标。总是覆盖。返回 'copied' | 'error'"""
    dst = dst_dir / src.name

    if dry_run:
        return "copied"

    try:
        if dst.exists():
            if dst.is_dir():
                shutil.rmtree(dst)
            else:
                dst.unlink()

        if src.is_dir():
            shutil.copytree(src, dst)
        else:
            shutil.copy2(src, dst)
        return "copied"
    except Exception as e:
        return f"error: {e}"


def create_docs_skeleton(target: Path, mode: str, dry_run: bool = False) -> dict:
    """创建 docs/ 目录骨架。返回 {路径: 动作}"""
    docs_dir = target / "docs"
    results = {}

    # 创建 docs/ 目录
    if not dry_run:
        docs_dir.mkdir(parents=True, exist_ok=True)

    # 1. 创建子目录
    for subdir in DOCS_SKELETON_DIRS:
        dirpath = docs_dir / subdir
        if dirpath.exists():
            results[subdir + "/"] = "skipped"
            continue
        if not dry_run:
            dirpath.mkdir(parents=True, exist_ok=True)
            # 空目录加 .gitkeep 以纳入 git
            (dirpath / ".gitkeep").touch()
        results[subdir + "/"] = "created"

    # 2. 创建文件
    for relpath, content in DOCS_SKELETON_FILES.items():
        filepath = docs_dir / relpath
        if filepath.exists() and mode == "existing":
            results[relpath] = "skipped"
            continue
        if dry_run:
            results[relpath] = "created" if not filepath.exists() else "skipped"
        else:
            filepath.parent.mkdir(parents=True, exist_ok=True)
            filepath.write_text(content, encoding="utf-8")
            results[relpath] = "created"

    return results


def cleanup_old_templates(target: Path, dry_run: bool = False) -> list:
    """删除旧版模板中不再存在于当前框架的文件/目录"""
    removed = []

    for relpath in OLD_TEMPLATE_FILES:
        filepath = target / relpath
        if filepath.exists():
            if not dry_run:
                filepath.unlink()
            removed.append(f"🗑 {relpath}")

    for relpath in OLD_TEMPLATE_DIRS:
        dirpath = target / relpath
        if dirpath.exists():
            if not dry_run:
                shutil.rmtree(dirpath)
            removed.append(f"🗑 {relpath}/")

    return removed


def generate_gitignore(target: Path, dry_run: bool = False) -> str:
    """生成 .gitignore。已有则跳过。"""
    filepath = target / ".gitignore"
    if filepath.exists():
        return "skipped"
    if not dry_run:
        filepath.write_text(GITIGNORE_CONTENT, encoding="utf-8")
    return "created"


# ═══════════════════════════════════════════════════════════
# 输出
# ═══════════════════════════════════════════════════════════

def print_new_project_help(target: str):
    print()
    print(color("✅ YuanForge (DocsOS) 初始化完成", "green"))
    print(f"📂 {target}")
    print()
    print(color("╔══════════════════════════════════════════╗", "cyan"))
    print(color("║  🚀 下一步                                ║", "cyan"))
    print(color("╠══════════════════════════════════════════╣", "cyan"))
    print(color("║  向 Conductor 描述你的需求:               ║", "cyan"))
    print(color('║  "我要做一个 xxx"                        ║', "cyan"))
    print(color("║  Conductor 启动 12 人专家团               ║", "cyan"))
    print(color("╚══════════════════════════════════════════╝", "cyan"))
    print()


def print_existing_project_help(target: str, cleaned: list):
    print()
    print(color("✅ YuanForge (DocsOS) 嫁接 / 更新完成", "green"))
    print(f"📂 {target}")
    if cleaned:
        print()
        print(color("🧹 已清理旧模板:", "yellow"))
        for item in cleaned:
            print(f"  {item}")
    print()
    print(color("╔══════════════════════════════════════════╗", "cyan"))
    print(color("║  🚀 下一步                                ║", "cyan"))
    print(color("╠══════════════════════════════════════════╣", "cyan"))
    print(color("║  1. 先补全项目文档:                       ║", "cyan"))
    print(color("║     「请审计当前项目，生成 docs/ 文档」    ║", "cyan"))
    print(color("║  2. 再描述新需求:                         ║", "cyan"))
    print(color("║     「在现有项目基础上，我要增加 xxx」      ║", "cyan"))
    print(color("╚══════════════════════════════════════════╝", "cyan"))
    print()


# ═══════════════════════════════════════════════════════════
# 主逻辑
# ═══════════════════════════════════════════════════════════

def main():
    parser = argparse.ArgumentParser(
        description="YuanForge DocsOS 项目初始化 / 框架更新",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=textwrap.dedent("""\
            示例:
              yuanforge-init ./my-app                          从零开始
              yuanforge-init ./my-app --name "用户认证系统"      指定项目名
              yuanforge-init ./existing --mode existing         嫁接已有项目
              yuanforge-init ./existing --mode existing --clean 嫁接 + 清理旧模板
              yuanforge-init ./project --mode existing --update 仅更新框架文件
              yuanforge-init ./my-app --dry-run                 预览
        """),
    )
    parser.add_argument("target", help="目标项目目录")
    parser.add_argument("--name", default=None, help="项目名称")
    parser.add_argument(
        "--mode", choices=["new", "existing"], default="new",
        help="new=从零开始(默认), existing=嫁接/更新已有项目",
    )
    parser.add_argument("--update", action="store_true",
                        help="仅更新框架文件，不操作 docs/（需配合 --mode existing）")
    parser.add_argument("--clean", action="store_true",
                        help="删除旧版模板中不再使用的文件/目录（需配合 --mode existing）")
    parser.add_argument("--dry-run", action="store_true", help="只显示会做什么，不执行")
    parser.add_argument("--force", action="store_true", help="跳过确认")

    args = parser.parse_args()
    target = Path(args.target).resolve()

    # 验证源目录
    for item in FRAMEWORK_ITEMS:
        src = SOURCE_ROOT / item
        if not src.exists():
            print(color(f"✗ 框架文件缺失: {src}", "red"))
            print("  请确保从 yuanforge 仓库根目录运行此脚本")
            sys.exit(1)

    # ═══ 模式验证 ═══
    if args.mode == "new":
        if target.exists() and any(target.iterdir()):
            print(color(f"✗ 目标目录已有文件: {target}", "red"))
            print("  --mode new 要求目标目录不存在或为空")
            print("  如果是已有项目，请使用 --mode existing")
            sys.exit(1)
    elif args.mode == "existing":
        if not target.exists():
            print(color(f"✗ 目标目录不存在: {target}", "red"))
            print("  --mode existing 要求目标目录已存在")
            sys.exit(1)

    # ═══ 确认 ═══
    if not args.force and not args.dry_run:
        print()
        print(f"  目标: {target}")
        if args.mode == "new":
            print("  模式: 从零开始")
        elif args.update:
            print("  模式: 仅更新框架文件")
        else:
            print("  模式: 嫁接已有项目")
        if args.clean:
            print("  清理旧模板: 是")
        print()
        confirm = input("  确认? [Y/n] ").strip().lower()
        if confirm and confirm != "y":
            print("  已取消")
            sys.exit(0)

    # ═══ 执行 ═══
    if args.dry_run:
        print(color("\n🔍 预览模式 — 不会实际修改文件\n", "yellow"))

    if not args.dry_run:
        target.mkdir(parents=True, exist_ok=True)

    # 1. 清理旧模板
    cleaned = []
    if args.clean and args.mode == "existing":
        print(color("🧹 清理旧模板:", "bold"))
        cleaned = cleanup_old_templates(target, args.dry_run)
        if cleaned:
            for item in cleaned:
                print(f"  {item}")
        else:
            print("  · 没有需要清理的旧模板")

    # 2. 复制框架文件
    print(color("\n📋 同步框架文件:", "bold"))
    for item in FRAMEWORK_ITEMS:
        src = SOURCE_ROOT / item
        status = copy_framework_item(src, target, args.dry_run)
        if status == "copied":
            marker = "↻ 更新" if (target / item).exists() else "✓ 新增"
            print(f"  {marker}  {item}")
        else:
            print(color(f"  ✗ {item} → {status}", "red"))

    # 3. 生成 docs/（update 模式跳过）
    if not args.update:
        print(color("\n📄 生成 docs/ 骨架:", "bold"))
        doc_results = create_docs_skeleton(target, args.mode, args.dry_run)
        for relpath, action in doc_results.items():
            if action == "created":
                print(f"  ✓ docs/{relpath}")
            else:
                print(f"  · docs/{relpath} → 跳过（已存在）")
    else:
        print(color("\n📄 docs/ → 跳过（--update 模式不操作 docs/）", "bold"))

    # 4. .gitignore
    print(color("\n📄 .gitignore:", "bold"))
    git_status = generate_gitignore(target, args.dry_run)
    if git_status == "created":
        print("  ✓ .gitignore")
    else:
        print("  · .gitignore → 跳过（已存在）")

    # 5. git init (仅 new 模式)
    if args.mode == "new" and not args.dry_run:
        print(color("\n📦 git init:", "bold"))
        import subprocess
        result = subprocess.run(
            ["git", "init"], cwd=target, capture_output=True, text=True
        )
        print(f"  {result.stdout.strip()}")

    # ═══ 完成 ═══
    if args.dry_run:
        print(color("\n🔍 预览完成 — 以上操作不会实际执行", "yellow"))
        return

    if args.mode == "new":
        print_new_project_help(str(target))
    else:
        print_existing_project_help(str(target), cleaned)


if __name__ == "__main__":
    main()
